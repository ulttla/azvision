# Backend
AZVISION_ENV=development
AZVISION_DEBUG=true
AZVISION_API_V1_PREFIX=/api/v1
AZVISION_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AZVISION_DATABASE_URL=sqlite:///./azvision.db

# Azure (Phase 1A live read wiring)
AZURE_TENANT_ID=
